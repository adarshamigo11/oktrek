# OKTREK Production Environment
# Generate secure secrets before deploying.

NODE_ENV=production
PORT=4000
APP_URL=https://yourdomain.com

# SQLite (default for small sites). For MySQL, use:
# DATABASE_URL=mysql://user:password@127.0.0.1:3306/trekonindia
DATABASE_URL=sqlite:./data/prod.sqlite3

# Secrets — run: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Use 64-char strings for SESSION_SECRET and 32-char strings for CSRF/SIGNED_LINK/IP_HASH.
SESSION_SECRET=CHANGE_ME_64B_MINIMUM_LENGTH_SECRET
CSRF_SECRET=CHANGE_ME_32B
SIGNED_LINK_SECRET=CHANGE_ME_32B
IP_HASH_SECRET=CHANGE_ME_32B
AES_KEY_MFA=CHANGE_ME_32B_BASE64

# SMTP (leave HOST empty to log emails instead of sending)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Trek On India <bookings@trekonindia.com>"
MAIL_OPS=ops@trekonindia.com

# hCaptcha (empty skips verification)
CAPTCHA_SECRET=

TRUST_PROXY=0
LOG_LEVEL=info
